; Engine configuration file.

config_version=5

[application]
config/name="GreyboxController"
run/main_scene="res://Main.tscn"

[autoload]
GodotAgentRuntime="*res://addons/godot_agent_runtime/agent_runtime.gd"
AgentHooks="*res://AgentHooks.cs"

[display]
window/size/viewport_width=960
window/size/viewport_height=540

[dotnet]
project/assembly_name="GreyboxController"
