{
  "name": "greybox-smoke",
  "description": "Reset the world, move right, jump, validate semantic state, and capture a frame.",
  "steps": [
    {
      "type": "hook",
      "method": "reset_world",
      "arguments": []
    },
    {
      "type": "wait",
      "milliseconds": 150
    },
    {
      "type": "input",
      "kind": "action",
      "action": "move_right",
      "pressed": true
    },
    {
      "type": "wait",
      "milliseconds": 450
    },
    {
      "type": "input",
      "kind": "action",
      "action": "move_right",
      "pressed": false
    },
    {
      "type": "input",
      "kind": "action",
      "action": "jump",
      "pressed": true
    },
    {
      "type": "wait",
      "milliseconds": 100
    },
    {
      "type": "input",
      "kind": "action",
      "action": "jump",
      "pressed": false
    },
    {
      "type": "wait",
      "milliseconds": 650
    },
    {
      "type": "hook",
      "method": "get_semantic_state",
      "arguments": []
    },
    {
      "type": "assert",
      "path": "result.movedRightEnough",
      "equals": true
    },
    {
      "type": "assert",
      "path": "result.jumped",
      "equals": true
    },
    {
      "type": "inspect",
      "target": "scene"
    },
    {
      "type": "capture",
      "label": "greybox-jump"
    },
    {
      "type": "quit"
    }
  ]
}
