; Engine configuration file.
; Minimal smoke project for runtime verification.

config_version=5

[application]
config/name="MinimalGameCSharp"
run/main_scene="res://main.tscn"

[autoload]
GodotAgentRuntime="*res://addons/godot_agent_runtime/agent_runtime.gd"

[dotnet]
project/assembly_name="MinimalGameCSharp"

[display]
window/size/viewport_width=640
window/size/viewport_height=360
